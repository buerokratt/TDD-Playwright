{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["utils/*"],
      "@pages/*": ["page-objects/*"],
      "@setup/*": ["tests/.setup/*"],
      "@auth/*": ["tests/admin/.auth/*"]
    },
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["tests/**/*", "utils/**/*", "page-objects/**/*", "*.ts"],
  "exclude": ["node_modules"]
}
